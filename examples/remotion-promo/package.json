{
  "name": "elephant-remotion-promo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "mkdir -p ../../artifacts/remotion && remotion render src/index.ts ElephantPromo ../../artifacts/remotion/elephant-promo-demo.mp4 --codec=h264 --crf=18",
    "render:web": "mkdir -p ../../web/public/media && remotion render src/index.ts ElephantPromo ../../web/public/media/elephant-home-demo.mp4 --codec=h264 --crf=18"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "remotion": "4.0.391"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.391",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}
