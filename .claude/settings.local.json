{
  "permissions": {
    "allow": [
      "Bash(grep -r \"cc.*subscription\" /Users/bytedance/code/elephant.ai --include=\"*.md\" --include=\"*.yaml\" --include=\"*.yml\" --include=\"*.sh\" --include=\"*.py\" 2>/dev/null | head -20)",
      "Read(//Users/bytedance/.claude/**)",
      "Bash(go run:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ELEPHANT_HOOKS_URL='http://localhost:9090' \"$CLAUDE_PROJECT_DIR\"/scripts/cc_hooks/notify_lark.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ELEPHANT_HOOKS_URL='http://localhost:9090' \"$CLAUDE_PROJECT_DIR\"/scripts/cc_hooks/notify_lark.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "prefersReducedMotion": true
}
