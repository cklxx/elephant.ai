{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ELEPHANT_HOOKS_URL='http://localhost:9090' \"$CLAUDE_PROJECT_DIR\"/scripts/cc_hooks/notify_lark.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ELEPHANT_HOOKS_URL='http://localhost:9090' \"$CLAUDE_PROJECT_DIR\"/scripts/cc_hooks/notify_lark.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "prefersReducedMotion": true
}
